FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=dev-secret-key
JWT_SECRET_KEY=dev-jwt-secret
DATABASE_URL=sqlite:///app.db
SUPERADMIN_BOOTSTRAP_TOKEN=change-this-token
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://resto-manager.netlify.app

# Imgur Configuration (for image upload)
IMGUR_CLIENT_ID=your_imgur_client_id

# FreeImageHost configuration (for image upload proxy)
FREEIMAGE_API_KEY=your_freeimage_api_key
