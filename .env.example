FLASK_APP=run.py
FLASK_ENV=development

# ===========================================
# Database Configuration
# ===========================================
# Choose database type: sqlite, mysql, or postgresql
DB_TYPE=sqlite

# Option 1: SQLite (for development/testing)
# Default: sqlite:///app.db (stored in instance folder)
DATABASE_URL=sqlite:///app.db

# Option 2: MySQL (for production) - Use individual variables
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=restaurant_db

# Option 3: MySQL - Use full DATABASE_URL (overrides individual settings)
# DB_TYPE=mysql
# DATABASE_URL=mysql+pymysql://username:password@host:port/database?charset=utf8mb4

# Option 4: PostgreSQL (for production)
# DB_TYPE=postgresql
# DATABASE_URL=postgresql://username:password@host:port/database

# ===========================================
# Security Keys
# ===========================================
SECRET_KEY=dev-secret-key
JWT_SECRET_KEY=dev-jwt-secret
SUPERADMIN_BOOTSTRAP_TOKEN=change-this-token

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://resto-manager.netlify.app

# ===========================================
# Image Upload Configuration
# ===========================================
IMGUR_CLIENT_ID=your_imgur_client_id
FREEIMAGE_API_KEY=your_freeimage_api_key

# Upload folder (optional, defaults to app/static/uploads)
# UPLOAD_FOLDER=/path/to/uploads

